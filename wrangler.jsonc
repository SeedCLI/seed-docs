{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "seed-docs",
  "compatibility_date": "2026-03-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker/index.ts",
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  }
}
